# Copy to .env for local dev. Required values must be set before
# the server will start.

# --- required ---
# Random string of >= 32 chars. Used to sign session cookies.
# Generate with e.g. `openssl rand -hex 32`
TUNEFETCH_SECRET=

# --- optional ---
# Where the SQLite DB and any persistent files live.
# Defaults to /app/data inside the container, ./data locally.
TUNEFETCH_DATA_DIR=./data

# Pre-seed the admin account on first run instead of using the
# in-app setup flow. Both must be set together.
TUNEFETCH_ADMIN_USER=
TUNEFETCH_ADMIN_PASSWORD=

# Controls the `Secure` attribute on the session cookie.
#   auto  (default) — Secure when the request URL scheme is https.
#   true            — always Secure (behind an HTTPS reverse proxy).
#   false           — never Secure (plain-HTTP LAN deployment).
# If login appears to loop on a plain-HTTP LAN deployment, set this to false.
TUNEFETCH_COOKIE_SECURE=auto

# --- container only ---
# File ownership mapping for Unraid. Ignored outside Docker.
PUID=1000
PGID=1000
